model MstCompany {
  id          Int       @id @default(autoincrement())
  code        String
  name        String
  legal_name  String
  alias       String?
  description String?   @db.Text
  is_active   Int       @default(1)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  created_by  Int?
  updated_by  Int?
  deleted_by  Int?

  departments MstDepartment[]

  @@map("mst_companies")
}
